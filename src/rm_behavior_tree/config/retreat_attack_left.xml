<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4" main_tree_to_execute="BehaviorTree">
  <!-- 根节点，指定行为树的 ID -->
  <BehaviorTree ID="BehaviorTree">
    <!-- 反应序列节点（ReactiveSequence）：顺序执行子节点，直到其中一个失败 -->
    <ReactiveSequence>
      <!-- 订阅游戏的状态信息 -->
      <SubGameStatus topic_name="game_status" game_status="{game_status}"/>
      
      <!-- 回退节点（Fallback）：尝试执行子节点，直到其中一个成功 -->
      <Fallback>
        <!-- 检查游戏状态是否为 1 -->
        <Sequence>
          <IsGameTime name="IsGameStart1" 
                      message="{game_status}" 
                      game_progress="1" 
                      lower_remain_time="0" 
                      higher_remain_time="10000"/>
          <SendGoal name="PointA" 
                    goal_pose="4.99;0.85;0; 0;0;0;1;" 
                    action_name="navigate_to_pose"/>
        </Sequence>
        
        <!-- 检查游戏状态是否为 2 -->
        <Sequence>
          <IsGameTime name="IsGameStart2" 
                      message="{game_status}" 
                      game_progress="2" 
                      lower_remain_time="0" 
                      higher_remain_time="10000"/>
          <SendGoal name="PointC" 
                    goal_pose="-0.55;-4.35;0; 0;0;0;1" 
                    action_name="navigate_to_pose"/>
        </Sequence>
      </Fallback>
    </ReactiveSequence>
  </BehaviorTree>
</root>
